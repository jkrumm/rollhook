# Required — any string works for local dev
ADMIN_TOKEN=admin
WEBHOOK_TOKEN=webhook

# Optional — Pushover notifications
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Optional — disk usage & retention (defaults shown)
# Most-recently-pushed tags kept per repo in the built-in registry. 0 keeps everything forever.
ROLLHOOK_REGISTRY_KEEP_TAGS=5
# Docker images kept per app on the host after a deploy (plus the just-deployed tag, always kept). 0 disables pruning.
# Only prunes images that still carry a repo tag — apps reusing a moving tag like `:latest` leave untagged layers behind; use `docker image prune` for those.
ROLLHOOK_IMAGE_KEEP_COUNT=5
# Days a job log file is kept before the reaper deletes it. 0 disables pruning.
ROLLHOOK_LOG_RETENTION_DAYS=30
